{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 24,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "defaults",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "installDir": "${sourceDir}/install",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "On",
                "CMAKE_COMPILE_WARNING_AS_ERROR": "On"
            }
        },
        {
            "name": "host",
            "displayName": "Configuration for Host Tooling and Tests",
            "inherits": "defaults",
            "cacheVariables": {
                "CMAKE_CONFIGURATION_TYPES": "Debug;Release;RelWithDebInfo;MinSizeRel",
                "CAN_LITE_BUILD_TESTS": true
            },
            "generator": "Ninja Multi-Config"
        },
        {
            "name": "host-single-Debug",
            "displayName": "Configuration for Host Tooling and Tests, Single Config Generator, Debug",
            "inherits": "defaults",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CAN_LITE_BUILD_TESTS": true
            }
        },
        {
            "name": "windows",
            "displayName": "Windows cross compilation",
            "inherits": "defaults",
            "toolchainFile": "${sourceDir}/embedded-infra-lib/cmake/toolchain-clang-x86_64-pc-windows-msvc.cmake",
            "cacheVariables": {
                "CMAKE_COMPILE_WARNING_AS_ERROR": "Off",
                "CMAKE_CONFIGURATION_TYPES": "Debug;Release;RelWithDebInfo;MinSizeRel",
                "CMAKE_PREFIX_PATH": "/opt/qt6-windows/6.4.2/msvc2019_64",
                "CMAKE_CXX_FLAGS": "/EHsc -D_ALLOW_COMPILER_AND_STL_VERSION_MISMATCH",
                "CAN_LITE_BUILD_TESTS": true
            },
            "generator": "Ninja Multi-Config"
        },
        {
            "name": "coverage",
            "displayName": "coverage",
            "description": "Configuration for code coverage",
            "inherits": "host",
            "cacheVariables": {
                "EMIL_ENABLE_COVERAGE": "On"
            },
            "generator": "Ninja"
        }
    ],
    "buildPresets": [
        {
            "name": "host-Release",
            "configuration": "Release",
            "configurePreset": "host"
        },
        {
            "name": "host-Release-WithPackage",
            "configuration": "Release",
            "configurePreset": "host",
            "targets": [
                "all",
                "package"
            ]
        },
        {
            "name": "host-RelWithDebInfo",
            "configuration": "RelWithDebInfo",
            "configurePreset": "host"
        },
        {
            "name": "host-Debug",
            "configuration": "Debug",
            "configurePreset": "host"
        },
        {
            "name": "host-Debug-WithPackage",
            "configuration": "Debug",
            "configurePreset": "host",
            "targets": [
                "all",
                "package"
            ]
        },
        {
            "name": "host-single-Debug",
            "configuration": "Debug",
            "configurePreset": "host-single-Debug"
        },
        {
            "name": "windows-RelWithDebInfo",
            "configuration": "RelWithDebInfo",
            "configurePreset": "windows"
        },
        {
            "name": "windows-Debug",
            "configuration": "Debug",
            "configurePreset": "windows"
        },
        {
            "name": "coverage",
            "configuration": "Debug",
            "configurePreset": "coverage"
        }
    ],
    "testPresets": [
        {
            "name": "defaults",
            "hidden": true,
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error",
                "stopOnFailure": true
            }
        },
        {
            "name": "host",
            "configurePreset": "host",
            "configuration": "Debug",
            "inherits": "defaults"
        },
        {
            "name": "coverage",
            "configurePreset": "coverage",
            "configuration": "Debug",
            "inherits": "defaults"
        },
        {
            "name": "host-single-Debug",
            "configurePreset": "host-single-Debug",
            "configuration": "Debug",
            "inherits": "defaults"
        }
    ]
}
