{
  "build": {
    "context": "..",
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--add-host=host.docker.internal:host-gateway",
    "--privileged",
    "--shm-size=256m"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "JacquesLucke.gcov-viewer@0.5.0",
        "matepek.vscode-catch2-test-adapter@4.12.2",
        "anthropics.claude-code@2.1.162"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "files.insertFinalNewline": true,
        "gcovViewer.buildDirectories": [
          "${workspaceFolder}/build/Coverage"
        ],
        "gcovViewer.highlightMissedLines": true
      }
    }
  },
  "postCreateCommand": {
    "submodule.update": "git submodule update --init --recursive",
    "config.core.autocrlf": "git config --replace-all core.autocrlf false",
    "config.core.eol": "git config --replace-all core.eol lf",
    "config.core.editor": "git config --global core.editor 'code --wait'"
  }
}
